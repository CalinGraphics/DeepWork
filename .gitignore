# VS Code / Cursor
.vscode/

# Kotlin tooling (cache incremental locala)
.kotlin/

# Ieșiri manuale / alternative de compile
**/bin/
**/out/

# NDK / CMake
.externalNativeBuild/
.cxx/

# Captură ecran / profiling
/captures/

# OS
.DS_Store
Thumbs.db

