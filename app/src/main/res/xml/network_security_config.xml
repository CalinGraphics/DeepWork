<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Companionul folosește ws:// (fără TLS) pe LAN, USB (127.0.0.1) și emulator. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
